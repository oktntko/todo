{
  "name": "todo-express",
  "version": "0.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "debug": "vite --debug --inspect-brk",
    "build": "vite build",
    "db": "npm-run-all --sequential db:*",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "test": "DATABASE_URL='postgresql://todo:todo@localhost:5432/unit_test' vitest",
    "test:cov": "DATABASE_URL='postgresql://todo:todo@localhost:5432/unit_test' vitest run --coverage",
    "test:db": "DATABASE_URL='postgresql://todo:todo@localhost:5432/unit_test' npm-run-all --sequential db:*",
    "lint": "eslint --ext .js,.ts src",
    "ncu": "ncu --target minor",
    "openapi": "curl http://localhost:8080/openapi > openapi.json && openapi-typescript openapi.json --output schema.ts --export-type"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^3.15.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.13.2",
    "class-validator-jsonschema": "^3.1.1",
    "dayjs": "^1.11.3",
    "express": "^4.18.1",
    "helmet": "^5.1.0",
    "http-errors": "^2.0.0",
    "log4js": "^6.5.2",
    "reflect-metadata": "^0.1.13",
    "routing-controllers": "^0.9.0",
    "routing-controllers-openapi": "^3.1.0"
  },
  "devDependencies": {
    "@swc/core": "^1.2.198",
    "@types/body-parser": "^1.19.2",
    "@types/express": "^4.17.13",
    "@types/http-errors": "^1.8.2",
    "@types/multer": "^1.4.7",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^5.27.1",
    "@typescript-eslint/parser": "^5.27.1",
    "c8": "^7.11.3",
    "cors": "^2.8.5",
    "eslint": "^8.17.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.0.0",
    "kcors": "^2.2.2",
    "npm-check-updates": "^13.1.3",
    "npm-run-all": "^4.1.5",
    "openapi-typescript": "^5.4.0",
    "pm2": "^5.2.0",
    "prettier": "^2.6.2",
    "prisma": "^3.15.1",
    "supertest": "^6.2.3",
    "ts-node": "^10.8.1",
    "vite": "^2.9.12",
    "vite-plugin-node": "^1.0.0",
    "vitest": "^0.14.2"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.prisma.json prisma/seed.ts"
  }
}
