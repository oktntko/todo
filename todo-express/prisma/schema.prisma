generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Todo {
  todo_id     Int       @id @default(autoincrement())
  yarukoto    String?   @db.VarChar(100)
  order       Int?
  beginning   String?   @db.VarChar(10)
  deadline    String?   @db.VarChar(10)
  memo        String?   @db.VarChar(400)
  created_at  DateTime  @default(now()) @db.Timestamptz(3)
  updated_at  DateTime  @updatedAt @db.Timestamptz(3)
  done_at     DateTime? @db.Timestamptz(3)
  status_id   Int?
  category_id Int?
  project_id  Int?

  category Category? @relation(fields: [category_id], references: [category_id])
  project  Project?  @relation(fields: [project_id], references: [project_id])
  Status   Status?   @relation(fields: [status_id], references: [status_id])
  tags     TodoTag[]

  @@map("todos")
}

model Status {
  status_id   Int      @id @default(autoincrement())
  status_name String   @unique @db.VarChar(100)
  color       String   @db.VarChar(100)
  order       Int
  created_at  DateTime @default(now()) @db.Timestamptz(3)
  updated_at  DateTime @updatedAt @db.Timestamptz(3)
  todos       Todo[]

  @@map("statuses")
}

model Category {
  category_id   Int      @id @default(autoincrement())
  category_name String   @unique @db.VarChar(100)
  color         String   @db.VarChar(100)
  order         Int
  created_at    DateTime @default(now()) @db.Timestamptz(3)
  updated_at    DateTime @updatedAt @db.Timestamptz(3)
  todos         Todo[]

  @@map("categories")
}

model Project {
  project_id   Int      @id @default(autoincrement())
  project_name String   @unique @db.VarChar(100)
  order        Int
  created_at   DateTime @default(now()) @db.Timestamptz(3)
  updated_at   DateTime @updatedAt @db.Timestamptz(3)
  todos        Todo[]

  @@map("projects")
}

model Tag {
  tag_id     Int       @id @default(autoincrement())
  tag_name   String    @unique @db.VarChar(100)
  color      String    @db.VarChar(100)
  order      Int
  created_at DateTime  @default(now()) @db.Timestamptz(3)
  updated_at DateTime  @updatedAt @db.Timestamptz(3)
  todo_tags  TodoTag[]

  @@map("tags")
}

model TodoTag {
  id      Int  @id @default(autoincrement())
  todo_id Int
  tag_id  Int
  tag     Tag  @relation(fields: [tag_id], references: [tag_id], onDelete: Cascade)
  todo    Todo @relation(fields: [todo_id], references: [todo_id], onDelete: Cascade)

  @@unique([todo_id, tag_id], name: "unique_todo_id_tag_id")
  @@map("todo_tags")
}
