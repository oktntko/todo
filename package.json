{
  "name": "todo",
  "version": "1.0.0",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "dev": "turbo dev --ui=tui || true",
    "dev:msw": "pnpm --filter='@todo/vue' dev:msw",
    "build": "turbo build",
    "build:msw": "turbo build:msw",
    "type-check": "turbo type-check",
    "preview": "turbo preview --ui=tui || true",
    "generate": "pnpm --filter='@todo/prisma' 'prisma:generate'",
    "migrate": "pnpm --filter='@todo/prisma' 'prisma:migrate:dev'",
    "seed": "pnpm --filter='@todo/prisma' 'prisma:seed'",
    "lint": "turbo lint",
    "spell-check": "cspell .",
    "format": "turbo format",
    "test": "turbo test"
  },
  "devDependencies": {
    "@cspell/eslint-plugin": "^9.6.4",
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^24.10.4",
    "cspell": "^9.6.4",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "oxlint-tsgolint": "^0.14.2",
    "tsx": "^4.21.0",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.30.1"
}
