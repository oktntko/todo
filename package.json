{
  "name": "todo",
  "version": "1.0.0",
  "keywords": [],
  "license": "ISC",
  "author": "oktntko@gmail.com",
  "type": "module",
  "scripts": {
    "dev": "turbo dev --ui=tui || true",
    "dev:msw": "pnpm --filter='@todo/vue' dev:msw",
    "build": "turbo build",
    "build:msw": "turbo build:msw",
    "type-check": "turbo type-check",
    "preview": "turbo preview --ui=tui || true",
    "generate": "pnpm --filter='@todo/prisma' 'prisma:generate'",
    "migrate": "pnpm --filter='@todo/prisma' 'prisma:migrate:dev'",
    "seed": "pnpm --filter='@todo/prisma' 'prisma:seed'",
    "lint": "turbo lint",
    "spell-check": "cspell .",
    "format": "turbo format",
    "test": "turbo test"
  },
  "devDependencies": {
    "@cspell/eslint-plugin": "^9.7.0",
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "cspell": "^9.7.0",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.16",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.32.1"
}
