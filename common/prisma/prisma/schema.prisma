// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/client/generated"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../src/schema/generated"
}

datasource db {
  provider = "mysql"
}

/// @zod.import(["import { ColorSchema } from '@todo/lib/zod'", "import { AichatModelSchema } from '../../../option'"]);
model Space {
  space_id String @id @default(uuid(7)) @db.VarChar(36) /// @zod.length(36)

  space_name        String  @db.VarChar(100) /// @zod.trim().min(1).max(100)
  space_description String  @default("") @db.VarChar(400) /// @zod.max(400)
  space_image       String  @default(dbgenerated("('')")) @db.Text
  space_color       String  @default("") @db.VarChar(100) /// @zod.custom.use(ColorSchema.or(z.literal('')))
  /// AIチャットの有効化 `true`: 有効 / `false`: 無効
  aichat_enable     Boolean @default(false)
  /// AIチャットのAPIキー
  aichat_api_key    String  @default("") @db.VarChar(400) /// @zod.trim().max(400)

  group_list      Group[]
  whiteboard_list Whiteboard[]
  file_list       File[]
  space_user_list SpaceUser[]
  aichat_list     Aichat[]

  created_at DateTime @default(now()) @db.DateTime(3)
  created_by String
  updated_at DateTime @updatedAt @db.DateTime(3)
  updated_by String

  @@index([space_name])
  @@map("space")
}

/// @zod.import(["import { ColorSchema, StringRelationIdSchema } from '@todo/lib/zod'"]);
model Group {
  group_id String @id @default(uuid(7)) @db.VarChar(36) /// @zod.length(36)

  space_id String /// @zod.custom.use(StringRelationIdSchema)
  space    Space  @relation(fields: [space_id], references: [space_id], onDelete: Cascade)

  group_name        String @db.VarChar(100) /// @zod.trim().min(1).max(100)
  group_description String @default("") @db.VarChar(400) /// @zod.max(400)
  group_order       Int    @default(0)
  group_image       String @default(dbgenerated("('')")) @db.Text
  group_color       String @default("") @db.VarChar(100) /// @zod.custom.use(ColorSchema.or(z.literal('')))

  todo_list Todo[]

  created_at DateTime @default(now()) @db.DateTime(3)
  created_by String
  updated_at DateTime @updatedAt @db.DateTime(3)
  updated_by String

  @@index([group_name])
  @@map("group")
}

/// @zod.import(["import { DateSchema, TimeSchema, StringRelationIdSchema } from '@todo/lib/zod'"]);
model Todo {
  todo_id String @id @default(uuid(7)) @db.VarChar(36) /// @zod.length(36)

  group_id String /// @zod.custom.use(StringRelationIdSchema)
  group    Group  @relation(fields: [group_id], references: [group_id], onDelete: Cascade)

  title       String    @default("") @db.VarChar(100) /// @zod.trim().max(100)
  description String    @default(dbgenerated("('')")) @db.Text
  begin_date  String    @default("") @db.VarChar(10) /// @zod.custom.use(DateSchema.or(z.literal('')))
  begin_time  String    @default("") @db.VarChar(10) /// @zod.custom.use(TimeSchema.or(z.literal('')))
  limit_date  String    @default("") @db.VarChar(10) /// @zod.custom.use(DateSchema.or(z.literal('')))
  limit_time  String    @default("") @db.VarChar(10) /// @zod.custom.use(TimeSchema.or(z.literal('')))
  order       Int       @default(0)
  done_at     DateTime? @db.DateTime(3)

  file_list              File[]
  notification_todo_list NotificationTodo[]

  created_at DateTime @default(now()) @db.DateTime(3)
  created_by String
  updated_at DateTime @updatedAt @db.DateTime(3)
  updated_by String

  @@index([title])
  @@index([begin_date])
  @@index([limit_date])
  @@map("todo")
}

/// @zod.import(["import { StringRelationIdSchema } from '@todo/lib/zod'"]);
model Whiteboard {
  whiteboard_id String @id @default(uuid(7)) @db.VarChar(36) /// @zod.length(36)

  space_id String /// @zod.custom.use(StringRelationIdSchema)
  space    Space  @relation(fields: [space_id], references: [space_id], onDelete: Cascade)

  whiteboard_name        String @default("") @db.VarChar(100) /// @zod.trim().max(100)
  whiteboard_description String @default("") @db.VarChar(400) /// @zod.max(400)
  whiteboard_order       Int    @default(0)
  whiteboard_content     String @default(dbgenerated("('')")) @db.LongText

  created_at DateTime @default(now()) @db.DateTime(3)
  created_by String
  updated_at DateTime @updatedAt @db.DateTime(3)
  updated_by String

  @@map("whiteboard")
}

/// @zod.import(["import { StringRelationIdSchema } from '@todo/lib/zod'"]);
model Aichat {
  aichat_id String @id @default(uuid(7)) @db.VarChar(36) /// @zod.length(36)

  space_id String /// @zod.custom.use(StringRelationIdSchema)
  space    Space  @relation(fields: [space_id], references: [space_id], onDelete: Cascade)

  aichat_title String @default("") @db.VarChar(100) /// @zod.trim().max(100)

  aichat_message_list AichatMessage[]

  created_at DateTime @default(now()) @db.DateTime(3)
  created_by String
  updated_at DateTime @updatedAt @db.DateTime(3)
  updated_by String

  @@map("aichat")
}

/// @zod.import(["import { StringRelationIdSchema } from '@todo/lib/zod'", "import { AichatRoleSchema } from '../../../option'"]);
model AichatMessage {
  aichat_message_id String @id @default(uuid(7)) @db.VarChar(36) /// @zod.length(36)

  aichat_id String /// @zod.custom.use(StringRelationIdSchema)
  aichat    Aichat  @relation(fields: [aichat_id], references: [aichat_id], onDelete: Cascade)
  user_id   String? /// @zod.custom.use(StringRelationIdSchema.or(z.null()))
  user      User?   @relation(fields: [user_id], references: [user_id], onDelete: SetNull)

  role    String @db.VarChar(10) /// @zod.custom.use(AichatRoleSchema)
  content String @default(dbgenerated("('')")) @db.Text

  created_at DateTime @default(now()) @db.DateTime(3)
  created_by String
  updated_at DateTime @updatedAt @db.DateTime(3)
  updated_by String

  @@map("aichat_message")
}

////////////////////////////////
// 汎用機能
////////////////////////////////

/// ユーザ
model User {
  user_id String @id @default(uuid(7)) @db.VarChar(36) /// @zod.length(36)

  email        String  @unique @db.VarChar(255) /// @zod.email().trim().min(1).max(255)
  password     String  @db.VarChar(255) /// @zod.trim().min(1).max(255)
  username     String  @db.VarChar(100) /// @zod.trim().min(1).max(100)
  /// アバターイメージ
  avatar_image String  @default(dbgenerated("('')")) @db.Text
  /// 自己紹介
  description  String  @default("") @db.VarChar(400) /// @zod.trim().max(400)
  /// 二要素認証の有効化 `true`: 有効 / `false`: 無効
  twofa_enable Boolean @default(false)
  /// 二要素認証の秘密鍵
  twofa_secret String  @default("") @db.VarChar(255) /// @zod.trim().max(255)

  created_at DateTime @default(now()) @db.DateTime(3)
  updated_at DateTime @updatedAt @db.DateTime(3)

  session_list           Session[]
  space_user_list        SpaceUser[]
  aichat_message_list    AichatMessage[]
  notification_list      Notification[]
  notification_todo_list NotificationTodo[]

  @@index([username], name: "index_username")
  @@map("user")
}

model SpaceUser {
  id String @id @default(uuid(7)) @db.VarChar(36) /// @zod.length(36)

  user_id  String
  user     User   @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  space_id String
  space    Space  @relation(fields: [space_id], references: [space_id], onDelete: Cascade)

  role SpaceUserRole

  @@unique([user_id, space_id])
}

enum SpaceUserRole {
  OWNER
  ADMIN
  EDITOR
  READER
}

model Session {
  session_id String @id @default(uuid(7)) @db.VarChar(36) /// @zod.length(36)

  session_key    String    @unique @db.VarChar(255) /// @zod.trim().min(1).max(255)
  /// express-session
  originalMaxAge Int?
  expires        DateTime? @default(now()) @db.DateTime(3)
  /// custom
  user_id        String?
  data           String    @default(dbgenerated("('{}')")) @db.Text

  user User? @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.DateTime(3)
  updated_at DateTime @updatedAt @db.DateTime(3)

  @@map("session")
}

/// @zod.import(["import { StringRelationIdSchema } from '@todo/lib/zod'"]);
model File {
  file_id String @id @default(uuid(7)) @db.VarChar(36) /// @zod.length(36) 

  space_id String /// @zod.custom.use(StringRelationIdSchema)
  space    Space  @relation(fields: [space_id], references: [space_id], onDelete: Cascade)

  filename String @db.VarChar(255) /// @zod.trim().min(1).max(255)
  mimetype String @db.VarChar(100) /// @zod.trim().min(1).max(100)
  filesize Int

  created_at DateTime @default(now()) @db.DateTime(3)
  created_by String
  updated_at DateTime @updatedAt @db.DateTime(3)
  updated_by String

  todo_list Todo[]

  @@map("file")
}

enum NotificationStatus {
  PLANNING
  QUEUING
  UNREAD
  READ
}

/// @zod.import(["import { StringRelationIdSchema } from '@todo/lib/zod'"]);
model Notification {
  notification_id String @id @default(uuid(7)) @db.VarChar(36) /// @zod.length(36)

  user_id String /// @zod.custom.use(StringRelationIdSchema)
  user    User   @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  notification_title  String             @db.VarChar(400) /// @zod.trim().min(1).max(400)
  notification_body   String             @default("") @db.VarChar(400) /// @zod.trim().max(400)
  notification_link   String             @default("") @db.VarChar(400) /// @zod.trim().max(400)
  notification_status NotificationStatus
  notification_at     DateTime           @default(now()) @db.DateTime(3)

  created_at DateTime @default(now()) @db.DateTime(3)
  updated_at DateTime @updatedAt @db.DateTime(3)

  @@map("notification")
}

/// @zod.import(["import { StringRelationIdSchema } from '@todo/lib/zod'"]);
model NotificationTodo {
  notification_id String @id @default(uuid(7)) @db.VarChar(36) /// @zod.length(36)

  user_id String /// @zod.custom.use(StringRelationIdSchema)
  user    User   @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  todo_id String /// @zod.custom.use(StringRelationIdSchema)
  todo    Todo   @relation(fields: [todo_id], references: [todo_id], onDelete: Cascade)

  notification_title  String             @db.VarChar(400) /// @zod.trim().min(1).max(400)
  notification_body   String             @default("") @db.VarChar(400) /// @zod.trim().max(400)
  notification_link   String             @default("") @db.VarChar(400) /// @zod.trim().max(400)
  notification_status NotificationStatus
  notification_at     DateTime           @default(now()) @db.DateTime(3)

  created_at DateTime @default(now()) @db.DateTime(3)
  updated_at DateTime @updatedAt @db.DateTime(3)

  @@map("notification_todo")
}
