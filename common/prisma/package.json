{
  "name": "@todo/prisma",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    "./client": {
      "types": "./src/client/index.ts",
      "default": "./dist/client/index.mjs"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./dist/schema/index.mjs"
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsdown",
    "type-check": "tsc --project tsconfig.base.json --noEmit",
    "lint": "oxlint --type-aware --type-check",
    "format": "oxfmt",
    "prisma:generate": "prisma generate && find src/schema -type f | xargs sed -i -e \"s#from 'zod';#from '@todo/lib/zod';#g\" && tsx ../../script/generateBarrelFile.ts src/schema/generated/schemas/enums src/schema/option && oxfmt --write src/schema",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx src/seed.ts",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.3.0",
    "@prisma/client": "7.3.0",
    "@todo/lib": "workspace:*"
  },
  "devDependencies": {
    "prisma": "^7.3.0",
    "prisma-zod-generator": "^2.1.2",
    "tsdown": "^0.20.1"
  },
  "packageManager": "pnpm@10.28.1"
}
