{
  "name": "@todo/lib",
  "version": "1.0.0",
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "exports": {
    "./dayjs": {
      "types": "./src/dayjs.ts",
      "default": "./dist/dayjs.mjs"
    },
    "./remeda": {
      "types": "./src/remeda.ts",
      "default": "./dist/remeda.mjs"
    },
    "./zod": {
      "types": "./src/zod.ts",
      "default": "./dist/zod.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "type-check": "tsc --project tsconfig.base.json --noEmit",
    "lint": "oxlint --type-aware --type-check",
    "format": "oxfmt",
    "test": "vitest run",
    "test:preview": "vitest --ui"
  },
  "dependencies": {
    "dayjs": "^1.11.19",
    "remeda": "^2.33.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "tsdown": "^0.20.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.30.1"
}
