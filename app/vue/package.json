{
  "name": "@todo/vue",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:msw": "MODE='msw' run-s drizzle:generate && vite --mode msw",
    "build": "vite build",
    "build:msw": "MODE='msw' vite build --mode msw",
    "type-check": "vue-tsc --build --force tsconfig.app.json",
    "preview": "vite preview",
    "lint": "oxlint --type-aware --type-check",
    "format": "oxfmt",
    "test:unit": "vitest run",
    "test:preview": "vitest --ui",
    "test:e2e": "playwright test",
    "drizzle:generate": "drizzle-kit generate && tsx ./drizzle.generate-migrations.ts && oxfmt --write src/mock/migrations.json"
  },
  "dependencies": {
    "@daypilot/daypilot-lite-javascript": "^5.4.1",
    "@fontsource-variable/m-plus-1-code": "^5.2.9",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@todo/express": "workspace:*",
    "@todo/lib": "workspace:*",
    "@todo/prisma": "workspace:*",
    "@trpc/client": "11.13.4",
    "@vueuse/components": "^14.2.1",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.13.6",
    "fabric": "^7.2.0",
    "pinia": "^3.0.4",
    "sortablejs": "^1.15.7",
    "superjson": "^2.2.6",
    "use-vue-validate-schema": "^1.0.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.16",
    "@iconify/json": "^2.2.450",
    "@iconify/tailwind4": "^1.2.3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@trpc/server": "11.13.4",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/runtime-core": "^3.5.30",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "jsdom": "^29.0.0",
    "msw": "^2.12.11",
    "msw-trpc": "^2.0.1",
    "tailwindcss": "^4.2.1",
    "vue-component-type-helpers": "^3.2.5",
    "vue-tsc": "^3.2.5"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
